---
const rootId = `download-root-${crypto.randomUUID()}`;
const releaseBaseUrl = "https://github.com/DeepanshuMishraa/radius/releases/latest/download";
const fallbackUrl = "https://github.com/DeepanshuMishraa/radius/releases/latest";
---

<div id={rootId} class="flex flex-col items-center gap-4">
  <a
    href={fallbackUrl}
    data-primary-download
    class="download-btn group inline-flex items-center gap-2.5 px-7 py-3.5 text-[13px] font-medium text-radius-text-inverse bg-radius-accent rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-radius-accent focus-visible:ring-offset-2 focus-visible:ring-offset-radius-bg-primary"
  >
    <span data-download-icon class="flex items-center justify-center w-4 h-4 text-radius-text-inverse/90"></span>
    <span data-download-label>Download Beta</span>
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="download-arrow opacity-60"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
      <polyline points="7 10 12 15 17 10" />
      <line x1="12" x2="12" y1="15" y2="3" />
    </svg>
  </a>

  <div data-alt-downloads class="flex items-center gap-3 text-[11px] text-radius-text-muted">
    <!-- Populated by JS -->
  </div>
</div>

<script define:vars={{ rootId, releaseBaseUrl, fallbackUrl }}>
  function detectOS() {
    const platform =
      (navigator.userAgentData &&
        Array.isArray(navigator.userAgentData.platform)
        ? navigator.userAgentData.platform.join(" ")
        : navigator.userAgentData?.platform) ||
      navigator.platform ||
      "";
    const ua = navigator.userAgent.toLowerCase();
    const fingerprint = `${String(platform).toLowerCase()} ${ua}`;

    if (
      (fingerprint.includes("mac") ||
        fingerprint.includes("darwin")) &&
      !fingerprint.includes("iphone") &&
      !fingerprint.includes("ipad")
    ) {
      return "mac";
    }
    if (fingerprint.includes("win")) return "windows";
    if (fingerprint.includes("linux") || fingerprint.includes("x11")) return "linux";
    return "unknown";
  }

  function detectArch() {
    const ua = navigator.userAgent.toLowerCase();
    if (ua.includes("arm64") || ua.includes("aarch64")) return "arm64";
    if (ua.includes("x86_64") || ua.includes("x64") || ua.includes("amd64") || ua.includes("win64")) return "x64";
    if (navigator.platform === "MacIntel") {
      if (typeof navigator.userAgentData?.getHighEntropyValues === "function") {
        return null;
      }
      return "arm64";
    }
    return null;
  }

  const appleIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" class="w-4 h-4 fill-current"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>`;

  const windowsIcon = `<svg viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4"><path d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z" fill="#00adef"/></svg>`;

  const linuxIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 256 295"><defs><linearGradient id="linux-logosLinuxTux0" x1="48.548%" x2="51.047%" y1="115.276%" y2="41.364%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="linux-logosLinuxTux1" x1="54.407%" x2="46.175%" y1="2.404%" y2="90.542%"><stop offset="0%" stop-color="#FFF" stop-opacity=".8"/><stop offset="100%" stop-color="#FFF" stop-opacity="0"/></linearGradient><linearGradient id="linux-logosLinuxTux2" x1="51.86%" x2="47.947%" y1="88.248%" y2="9.748%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="linux-logosLinuxTux3" x1="49.925%" x2="49.924%" y1="85.49%" y2="13.811%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="linux-logosLinuxTux4" x1="53.901%" x2="45.956%" y1="3.102%" y2="93.895%"><stop offset="0%" stop-color="#FFF" stop-opacity=".65"/><stop offset="100%" stop-color="#FFF" stop-opacity="0"/></linearGradient><linearGradient id="linux-logosLinuxTux5" x1="45.593%" x2="54.811%" y1="5.475%" y2="93.524%"><stop offset="0%" stop-color="#FFF" stop-opacity=".65"/><stop offset="100%" stop-color="#FFF" stop-opacity="0"/></linearGradient><linearGradient id="linux-logosLinuxTux6" x1="49.984%" x2="49.984%" y1="89.845%" y2="40.632%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="linux-logosLinuxTux7" x1="53.505%" x2="42.746%" y1="99.975%" y2="23.545%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="linux-logosLinuxTux8" x1="49.841%" x2="50.241%" y1="13.229%" y2="94.673%"><stop offset="0%" stop-color="#FFF" stop-opacity=".8"/><stop offset="100%" stop-color="#FFF" stop-opacity="0"/></linearGradient></defs><path d="M127.713 282.635c-3.756 0-7.03-.543-9.812-1.627-2.783-1.084-5.006-2.655-6.67-4.712-1.663-2.057-2.529-4.584-2.596-7.58h9.396c.1 1.894.84 3.398 2.22 4.712 1.447 1.247 3.91 1.87 7.387 1.87 3.01 0 5.273-.54 6.789-1.62 1.582-1.147 2.373-2.618 2.373-4.41 0-1.597-.677-2.86-2.029-3.789-1.286-.996-3.483-1.859-6.593-2.59l-4.811-1.118c-4.697-1.084-8.24-2.75-10.634-4.997-2.33-2.314-3.494-5.218-3.494-8.714 0-2.44.677-4.626 2.029-6.555 1.42-1.929 3.36-3.42 5.823-4.47 2.462-1.117 5.224-1.676 8.285-1.676 2.927 0 5.557.492 7.89 1.476 2.395.917 4.29 2.24 5.689 3.97 1.447 1.665 2.22 3.615 2.22 5.853h-9.297c0-1.395-.611-2.546-1.833-3.454-1.155-.974-2.805-1.46-4.951-1.46-2.062 0-3.68.433-4.852 1.3-1.172.868-1.758 2.006-1.758 3.414 0 1.26.569 2.272 1.722 3.035 1.2.763 3.24 1.543 6.118 2.34l4.712 1.118c5.228 1.247 8.967 3.043 11.229 5.387 2.328 2.278 3.494 5.344 3.494 9.2 0 2.64-.778 5.002-2.33 7.086-1.489 2.016-3.55 3.576-6.186 4.676-2.564 1.1-5.474 1.653-8.737 1.653z" fill="url(#linux-logosLinuxTux0)"/><path d="M109.685 281.298c-1.962 3.105-4.835 5.47-8.618 7.096-3.72 1.56-8.063 2.34-13.03 2.34-4.692 0-8.832-.713-12.418-2.14-3.52-1.492-6.36-3.683-8.52-6.573-2.096-2.957-3.243-6.437-3.443-10.44h9.397c.2 2.757 1.413 4.927 3.64 6.51 2.293 1.584 5.473 2.376 9.542 2.376 3.343 0 6.027-.633 8.053-1.897 2.094-1.332 3.14-3.078 3.14-5.237 0-1.928-1.004-3.415-3.014-4.46-1.944-1.112-5.144-2.1-9.613-2.959l-5.308-1.017c-5.59-1.115-9.832-3.017-12.724-5.707-2.827-2.69-4.24-6.066-4.24-10.129 0-2.443.72-4.695 2.16-6.756 1.506-2.128 3.616-3.807 6.331-5.036 2.714-1.23 5.832-1.845 9.352-1.845 5.362 0 9.706 1.292 13.03 3.875 3.39 2.516 5.218 6.017 5.482 10.502h-9.098c-.2-2.293-1.246-4.096-3.14-5.402-1.828-1.372-4.52-2.057-8.073-2.057-2.88 0-5.247.585-7.099 1.757-1.785 1.105-2.678 2.577-2.678 4.413 0 1.662.827 2.994 2.478 3.997 1.652.936 4.384 1.804 8.193 2.604l5.407 1.118c5.822 1.181 10.318 3.085 13.478 5.71 3.226 2.56 4.839 5.953 4.839 10.18 0 2.71-.745 5.148-2.235 7.314z" fill="url(#linux-logosLinuxTux2)"/><path d="M151.728 287.71c-3.02 0-5.724-.54-8.113-1.62-2.39-1.084-4.29-2.655-5.7-4.712-1.41-2.057-2.19-4.584-2.382-7.58h9.396c.1 1.894.84 3.398 2.22 4.712 1.447 1.247 3.91 1.87 7.387 1.87 3.01 0 5.273-.54 6.789-1.62 1.582-1.147 2.373-2.618 2.373-4.41 0-1.597-.677-2.86-2.029-3.789-1.286-.996-3.483-1.859-6.593-2.59l-4.811-1.118c-4.697-1.084-8.24-2.75-10.634-4.997-2.33-2.314-3.494-5.218-3.494-8.714 0-2.44.677-4.626 2.029-6.555 1.42-1.929 3.36-3.42 5.823-4.47 2.462-1.117 5.224-1.676 8.285-1.676 2.927 0 5.557.492 7.89 1.476 2.395.917 4.29 2.24 5.689 3.97 1.447 1.665 2.22 3.615 2.22 5.853h-9.297c0-1.395-.611-2.546-1.833-3.454-1.155-.974-2.805-1.46-4.951-1.46-2.062 0-3.68.433-4.852 1.3-1.172.868-1.758 2.006-1.758 3.414 0 1.26.569 2.272 1.722 3.035 1.2.763 3.24 1.543 6.118 2.34l4.712 1.118c5.228 1.247 8.967 3.043 11.229 5.387 2.328 2.278 3.494 5.344 4.494 9.2 0 2.64-.778 5.002-2.33 7.086-1.489 2.016-3.55 3.576-6.186 4.676-2.564 1.1-5.474 1.653-8.737 1.653z" fill="url(#linux-logosLinuxTux3)"/><path d="M128 285.332h48.618c5.083 0 9.168-4.147 9.168-9.285V153.82c0-5.138-4.085-9.285-9.168-9.285H128z" fill="url(#linux-logosLinuxTux4)" opacity=".6"/><path d="M79.382 285.332H128V144.535H79.382c-5.083 0-9.168 4.147-9.168 9.285v122.227c0 5.138 4.085 9.285 9.168 9.285z" fill="url(#linux-logosLinuxTux5)" opacity=".6"/></svg>`;

  const intelIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/></svg>`;

  const downloadMap = {
    "mac-arm64": {
      label: "Download Beta for Mac (Apple Silicon)",
      icon: appleIcon,
      href: `${releaseBaseUrl}/stable-macos-arm64-Radius.dmg`,
    },
    "mac-x64": {
      label: "Download Beta for Mac (Intel)",
      icon: appleIcon,
      href: `${releaseBaseUrl}/stable-macos-x64-Radius.dmg`,
    },
    "mac-fallback": {
      label: "Download Beta for macOS",
      icon: appleIcon,
      href: `${releaseBaseUrl}/stable-macos-arm64-Radius.dmg`,
    },
    "windows-x64": {
      label: "Download Beta for Windows",
      icon: windowsIcon,
      href: `${releaseBaseUrl}/stable-win-x64-Radius-Setup.zip`,
    },
    "linux-x64": {
      label: "Download Beta for Linux",
      icon: linuxIcon,
      href: `${releaseBaseUrl}/stable-linux-x64-Radius-Setup.tar.gz`,
    },
  };

  const os = detectOS();
  const arch = detectArch();
  let primaryId;
  if (os === "mac") {
    primaryId = arch === "x64" ? "mac-x64" : "mac-arm64";
  } else if (os === "windows") {
    primaryId = "windows-x64";
  } else if (os === "linux") {
    primaryId = "linux-x64";
  }

  const primary = primaryId ? downloadMap[primaryId] : null;
  const root = document.getElementById(rootId);
  const btn = root?.querySelector("[data-primary-download]");
  const label = root?.querySelector("[data-download-label]");
  const iconEl = root?.querySelector("[data-download-icon]");

  function applyPrimary() {
    if (!btn || !primary) return;
    btn.href = primary.href;
    btn.removeAttribute("target");
    if (label) label.textContent = primary.label;
    if (iconEl) iconEl.innerHTML = primary.icon;
  }

  if (primary && arch !== null) {
    applyPrimary();
  } else if (os === "mac" && arch === null) {
    navigator.userAgentData?.getHighEntropyValues(["architecture", "bitness"])
      .then((hint) => {
        const detectedArch = hint?.architecture?.includes("arm") ? "arm64" : "x64";
        const resolved = detectedArch === "x64" ? "mac-x64" : "mac-arm64";
        Object.assign(primary || {}, downloadMap[resolved]);
        applyPrimary();
      })
      .catch(() => {
        Object.assign(primary || {}, downloadMap["mac-arm64"]);
        applyPrimary();
      });
  } else {
    if (label) label.textContent = "Download Beta";
  }

  const altContainer = root?.querySelector("[data-alt-downloads]");
  if (altContainer && os !== "unknown") {
    let altKeys;
    if (os === "mac") {
      const altArch = arch === "x64" ? "mac-arm64" : "mac-x64";
      altKeys = [altArch, "windows-x64", "linux-x64"];
    } else if (os === "windows") {
      altKeys = ["mac-arm64", "mac-x64", "linux-x64"];
    } else {
      altKeys = ["mac-arm64", "mac-x64", "windows-x64"];
    }
    altContainer.innerHTML = altKeys
      .map(
        (k) => `<a href="${downloadMap[k].href}" title="${downloadMap[k].label}" aria-label="${downloadMap[k].label}" class="alt-os-link flex items-center justify-center w-6 h-6">${k === "mac-x64" ? intelIcon : downloadMap[k].icon}</a>`
      )
      .join('<span class="text-radius-border">·</span>');
  } else if (altContainer) {
    const allKeys = ["mac-arm64", "mac-x64", "windows-x64", "linux-x64"];
    const shortLabels = {
      "mac-arm64": "Mac (Apple Silicon)",
      "mac-x64": "Mac (Intel)",
      "windows-x64": "Windows",
      "linux-x64": "Linux",
    };
    altContainer.innerHTML = allKeys
      .map(
        (k) => `<a href="${downloadMap[k].href}" title="${downloadMap[k].label}" aria-label="${downloadMap[k].label}" class="alt-os-link inline-flex items-center gap-1 text-radius-text-muted hover:text-radius-text-primary transition-colors duration-150">${k === "mac-x64" ? intelIcon : downloadMap[k].icon}<span>${shortLabels[k]}</span></a>`
      )
      .join('<span class="text-radius-border mx-1">·</span>');
  }
</script>
