---
const rootId = `download-root-${crypto.randomUUID()}`;
const latestReleaseUrl = "https://github.com/DeepanshuMishraa/radius/releases/latest";
---

<div id={rootId} class="flex flex-col items-center gap-4">
  <a
    href={latestReleaseUrl}
    data-primary-download
    target="_blank"
    rel="noopener"
    class="download-btn group inline-flex items-center gap-2.5 px-7 py-3.5 text-[13px] font-medium text-radius-text-inverse bg-radius-accent rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-radius-accent focus-visible:ring-offset-2 focus-visible:ring-offset-radius-bg-primary"
  >
    <span data-download-icon class="flex items-center justify-center w-4 h-4 text-radius-text-inverse/90"></span>
    <span data-download-label>Download</span>
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="download-arrow opacity-60"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
      <polyline points="7 10 12 15 17 10" />
      <line x1="12" x2="12" y1="15" y2="3" />
    </svg>
  </a>

  <div data-alt-downloads class="flex items-center gap-3 text-[11px] text-radius-text-muted">
    <!-- Populated by JS -->
  </div>
</div>

<script define:vars={{ rootId, latestReleaseUrl }}>
  function detectOS() {
    const platform =
      (navigator.userAgentData &&
        Array.isArray(navigator.userAgentData.platform)
        ? navigator.userAgentData.platform.join(" ")
        : navigator.userAgentData?.platform) ||
      navigator.platform ||
      "";
    const ua = navigator.userAgent.toLowerCase();
    const fingerprint = `${String(platform).toLowerCase()} ${ua}`;

    if (
      (fingerprint.includes("mac") ||
        fingerprint.includes("darwin")) &&
      !fingerprint.includes("iphone") &&
      !fingerprint.includes("ipad")
    ) {
      return "mac";
    }
    if (fingerprint.includes("win")) return "windows";
    if (fingerprint.includes("linux") || fingerprint.includes("x11")) return "linux";
    return "unknown";
  }

  const appleIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" class="w-4 h-4 fill-current"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>`;

  const windowsIcon = `<svg viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4"><path d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z" fill="#00adef"/></svg>`;

  const linuxIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 295" class="w-4 h-4"><path fill="#333" d="M127.9 0C80.5 0 42 38.5 42 85.9c0 31.5 16.9 59.1 42 74.3v133.8c0 5.5 4.5 10 10 10s10-4.5 10-10V160.2c24.1 14.5 40 41.5 40 72.7v62.1c0 5.5 4.5 10 10 10s10-4.5 10-10v-62.1c0-31.2 15.9-58.2 40-72.7v133.8c0 5.5 4.5 10 10 10s10-4.5 10-10V160.2c25.1-15.2 42-42.8 42-74.3C246 38.5 207.5 0 160.1 0h-32.2z"/><path fill="#FCC624" d="M160 85c0 13.8-11.2 25-25 25s-25-11.2-25-25 11.2-25 25-25 25 11.2 25 25z"/></svg>`;

  const downloads = {
    mac: {
      label: "Download for macOS",
      icon: appleIcon,
      href: latestReleaseUrl,
    },
    windows: {
      label: "Download for Windows",
      icon: windowsIcon,
      href: latestReleaseUrl,
    },
    linux: {
      label: "Download for Linux",
      icon: linuxIcon,
      href: latestReleaseUrl,
    },
    unknown: {
      label: "Download",
      icon: "",
      href: latestReleaseUrl,
    },
  };

  const os = detectOS();
  const primary = downloads[os] ?? downloads.unknown;

  const root = document.getElementById(rootId);
  const btn = root?.querySelector("[data-primary-download]");
  const label = root?.querySelector("[data-download-label]");
  const icon = root?.querySelector("[data-download-icon]");

  if (btn) {
    btn.href = primary.href;
  }
  if (label) label.textContent = primary.label;
  if (icon) icon.innerHTML = primary.icon;

  // Show alt OS links
  const altContainer = root?.querySelector("[data-alt-downloads]");
  if (altContainer && os !== "unknown") {
    const alts = ["mac", "windows", "linux"].filter((o) => o !== os);
    altContainer.innerHTML = alts
      .map(
        (o) => `<a href="${downloads[o].href}" title="${downloads[o].label}" aria-label="${downloads[o].label}" target="_blank" rel="noopener" class="alt-os-link flex items-center justify-center w-6 h-6">${downloads[o].icon}</a>`
      )
      .join('<span class="text-radius-border">·</span>');
  }
</script>
