---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 48 48"
  fill="none"
  class={className}
  xmlns="http://www.w3.org/2000/svg"
>
  <circle
    cx="24"
    cy="24"
    r="22"
    stroke="currentColor"
    stroke-width="1"
    stroke-opacity="0.12"
  />
  <circle
    cx="24"
    cy="24"
    r="16"
    stroke="currentColor"
    stroke-width="1"
    stroke-opacity="0.2"
  />
  <circle
    cx="24"
    cy="24"
    r="3"
    fill="currentColor"
    fill-opacity="0.9"
  />
</svg>