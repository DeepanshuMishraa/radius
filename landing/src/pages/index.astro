---
import RadiusMark from "../components/RadiusMark.astro";
import "../styles/global.css";

const releaseBaseUrl = "https://github.com/DeepanshuMishraa/radius/releases/latest/download";
const fallbackUrl = "https://github.com/DeepanshuMishraa/radius/releases/latest";

const downloadUrls = {
  macArm: `${releaseBaseUrl}/radius-macos-apple-silicon.dmg`,
  macIntel: `${releaseBaseUrl}/radius-macos-intel.dmg`,
  winX64: `${releaseBaseUrl}/radius-windows-x64.zip`,
  linuxX64: `${releaseBaseUrl}/radius-linux-x64.tar.gz`,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Radius — a minimal, fast, distraction-free desktop email client for Gmail. Read-only. Local cache. Zero clutter."
    />
    <meta name="theme-color" content="#e0dbd3" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Radius — A quiet place for your email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700,900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen flex flex-col justify-between">
    <!-- Header/Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-5 bg-radius-frame-bg/20 backdrop-blur-md border-b border-radius-border-subtle/10">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="#" class="nav-logo flex items-center gap-2.5 text-radius-text-primary group">
          <RadiusMark class="w-5 h-5 text-radius-accent transition-transform duration-300 group-hover:rotate-45" />
          <div class="flex items-center gap-2">
            <span class="text-[13px] font-semibold tracking-tight font-mono">Radius</span>
            <span class="text-[9px] font-mono font-medium px-1.5 py-0.5 rounded bg-radius-accent-subtle text-radius-text-secondary border border-radius-border-subtle/50 select-none">beta</span>
          </div>
        </a>
        <a
          href="https://github.com/DeepanshuMishraa/radius"
          target="_blank"
          rel="noopener"
          class="nav-link flex items-center gap-1.5 text-[12px] text-radius-text-secondary hover:text-radius-text-primary transition-colors duration-200 font-mono"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          <span>GitHub</span>
        </a>
      </div>
    </nav>

    <!-- Hero Content -->
    <main class="flex-1 flex flex-col justify-center pt-32 px-6">
      <div class="max-w-5xl mx-auto text-center w-full">
        <!-- Floating Brand Icon -->
        <div class="hero-icon mb-6 inline-flex items-center justify-center p-4 rounded-full bg-radius-bg-primary/50 border border-radius-border-subtle shadow-sm">
          <RadiusMark class="w-10 h-10 text-radius-accent" />
        </div>

        <!-- Pill badge -->
        <div class="mb-8">
          <a 
            href="https://github.com/DeepanshuMishraa/radius" 
            target="_blank" 
            rel="noopener"
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-radius-accent-subtle border border-radius-border-subtle hover:border-radius-border text-[11px] font-mono text-radius-text-secondary hover:text-radius-text-primary select-none transition-all duration-300 hover:scale-[1.02] shadow-sm hover:shadow-md"
          >
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-radius-accent animate-pulse"></span>
            <span>Now in Public Beta</span>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 transition-transform duration-300 group-hover:translate-x-0.5">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>

        <!-- Typography Heading -->
        <h1 class="font-satoshi text-[42px] sm:text-[56px] md:text-[68px] font-semibold text-radius-text-primary leading-[1.08] tracking-tight mb-6 max-w-3xl mx-auto select-none">
          A quiet place for your email.
        </h1>

        <!-- Short Tagline -->
        <p class="text-[14px] sm:text-[16px] text-radius-text-secondary leading-relaxed max-w-lg mx-auto mb-10 font-mono">
          A minimal, fast desktop client for Gmail. Cached locally. Zero clutter. Completely read-only.
        </p>

        <!-- OS Download & GitHub Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <!-- Dynamic OS Download Button -->
          <button
            type="button"
            id="primary-download-btn"
            class="download-btn w-full sm:w-auto group inline-flex flex-col items-start px-7 py-3.5 bg-radius-text-primary text-radius-bg-primary hover:opacity-95 rounded-xl shadow-sm focus:ring-2 focus:ring-radius-text-primary/30 outline-none cursor-pointer min-h-[58px] border border-radius-text-primary"
          >
            <div class="flex items-center gap-2.5">
              <!-- macOS Icon (Default hidden) -->
              <svg id="mac-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" class="w-4 h-4 fill-current hidden">
                <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z" />
              </svg>
              <!-- Windows Icon (Default hidden) -->
              <svg id="win-icon" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current hidden">
                <path d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z" />
              </svg>
              <!-- Generic/Linux Icon (Default) -->
              <svg id="generic-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <span id="primary-download-text" class="text-[13px] font-semibold tracking-wide">Download Beta for Desktop</span>
            </div>
            <span id="primary-download-subtext" class="text-[10px] opacity-80 font-mono mt-0.5 ml-6.5">Detecting system...</span>
          </button>

          <!-- Star us on GitHub Button -->
          <a
            href="https://github.com/DeepanshuMishraa/radius"
            target="_blank"
            rel="noopener"
            class="download-btn w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-7 py-3 bg-radius-bg-secondary hover:bg-radius-bg-tertiary text-radius-text-primary rounded-xl font-mono text-[12px] tracking-wide transition-all duration-200 border border-radius-border shadow-sm cursor-pointer min-h-[58px]"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-radius-text-primary">
              <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.132 9.21l8.2-1.192z"/>
            </svg>
            <span>Star us on GitHub</span>
          </a>
        </div>

        <!-- Centered, Cut-off App Preview Screen (Raw screenshot) -->
        <div class="preview-container dark:shadow-[0_-20px_50px_-15px_rgba(0,0,0,0.12)]">
          <picture>
            <source srcset="/of-dark.png" media="(prefers-color-scheme: dark)" />
            <img
              src="/of.png"
              alt="Radius Minimal Email Interface Screenshot"
              class="w-full select-none"
              loading="eager"
              draggable="false"
            />
          </picture>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="px-6 py-10 border-t border-radius-border-subtle/40 bg-radius-bg-primary/20">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 font-mono">
        <div class="flex items-center gap-2 text-radius-text-muted select-none">
          <RadiusMark class="w-4 h-4" />
          <span class="text-[11px]">Radius</span>
          <span class="text-[10px] text-radius-border">&middot;</span>
          <span class="text-[10px]">MIT License</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="/privacy" class="footer-link text-[11px] text-radius-text-muted hover:text-radius-text-secondary transition-colors duration-150">Privacy</a>
          <a href="/terms" class="footer-link text-[11px] text-radius-text-muted hover:text-radius-text-secondary transition-colors duration-150">Terms</a>
          <a href="https://github.com/DeepanshuMishraa/radius" target="_blank" rel="noopener" class="footer-link text-[11px] text-radius-text-muted hover:text-radius-text-secondary transition-colors duration-150">GitHub</a>
        </div>
      </div>
    </footer>

    <!-- macOS Manual Setup Dialog Overlay -->
    <dialog id="macos-dialog" closedby="any" class="w-full max-w-[28rem] bg-radius-bg-primary border border-radius-border rounded-2xl outline-none select-none text-left p-6 font-mono">
      <div class="flex flex-col gap-4">
        <!-- Dialog Header -->
        <div class="flex items-start justify-between border-b border-radius-border-subtle/60 pb-3">
          <div>
            <h3 class="text-[13px] font-semibold text-radius-text-primary">Installing on macOS</h3>
            <p class="text-[10px] text-radius-text-muted mt-0.5">Quarantine bypass for unsigned apps</p>
          </div>
          <button type="button" data-dialog-close class="text-radius-text-muted hover:text-radius-text-primary cursor-pointer transition-colors duration-150 p-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>

        <!-- Automatic download notice -->
        <div class="flex items-center gap-2 px-3 py-2 bg-radius-accent-subtle/30 rounded-lg text-radius-accent text-[10px]">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-radius-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-radius-accent"></span>
          </span>
          <span>Download started automatically...</span>
        </div>

        <!-- Quick instructions -->
        <div class="space-y-4 text-[11px] text-radius-text-secondary leading-relaxed">
          <div>
            <span class="text-radius-accent font-semibold">Step 1:</span> Drag <code class="bg-radius-bg-secondary px-1.5 py-0.5 rounded text-radius-text-primary text-[10px]">Radius.app</code> to your <code class="bg-radius-bg-secondary px-1.5 py-0.5 rounded text-radius-text-primary text-[10px]">/Applications</code> folder.
          </div>
          <div>
            <span class="text-radius-accent font-semibold">Step 2:</span> Paste this command into Terminal to clear the quarantine flag:
            <div class="flex items-stretch gap-1.5 mt-2 bg-radius-bg-secondary rounded-lg border border-radius-border-subtle p-2">
              <code id="mac-quarantine-cmd" class="flex-1 min-w-0 text-[10px] text-radius-text-primary leading-normal break-all select-all font-mono py-1">sudo xattr -rd com.apple.quarantine /Applications/Radius.app</code>
              <button
                type="button"
                id="copy-mac-cmd"
                class="shrink-0 p-1.5 rounded bg-radius-bg-primary hover:bg-radius-bg-secondary border border-radius-border-subtle/80 text-radius-text-muted hover:text-radius-text-primary transition-all duration-150 cursor-pointer"
                aria-label="Copy terminal command"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Manual downloads list -->
        <div class="border-t border-radius-border-subtle/50 pt-3">
          <p class="text-[9px] text-radius-text-muted mb-2">Need a specific version?</p>
          <div class="flex items-center gap-3 text-[10px]">
            <a href={downloadUrls.macArm} class="text-radius-accent hover:underline flex items-center gap-1">
              Apple Silicon
            </a>
            <span class="text-radius-border">&middot;</span>
            <a href={downloadUrls.macIntel} class="text-radius-accent hover:underline flex items-center gap-1">
              Intel Core
            </a>
          </div>
        </div>
      </div>
    </dialog>

    <!-- Windows Manual Setup Dialog Overlay -->
    <dialog id="windows-dialog" closedby="any" class="w-full max-w-[28rem] bg-radius-bg-primary border border-radius-border rounded-2xl outline-none select-none text-left p-6 font-mono">
      <div class="flex flex-col gap-4">
        <!-- Dialog Header -->
        <div class="flex items-start justify-between border-b border-radius-border-subtle/60 pb-3">
          <div>
            <h3 class="text-[13px] font-semibold text-radius-text-primary">Installing on Windows</h3>
            <p class="text-[10px] text-radius-text-muted mt-0.5">Windows SmartScreen instructions</p>
          </div>
          <button type="button" data-dialog-close class="text-radius-text-muted hover:text-radius-text-primary cursor-pointer transition-colors duration-150 p-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>

        <!-- Automatic download notice -->
        <div class="flex items-center gap-2 px-3 py-2 bg-radius-accent-subtle/30 rounded-lg text-radius-accent text-[10px]">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-radius-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-radius-accent"></span>
          </span>
          <span>Download started automatically...</span>
        </div>

        <!-- SmartScreen instructions -->
        <div class="space-y-4 text-[11px] text-radius-text-secondary leading-relaxed">
          <div>
            <span class="text-radius-accent font-semibold">Step 1:</span> Extract the downloaded <code class="bg-radius-bg-secondary px-1.5 py-0.5 rounded text-radius-text-primary text-[10px]">.zip</code> folder.
          </div>
          <div>
            <span class="text-radius-accent font-semibold">Step 2:</span> Open <code class="bg-radius-bg-secondary px-1.5 py-0.5 rounded text-radius-text-primary text-[10px]">Radius.exe</code>.
          </div>
          <div>
            <span class="text-radius-accent font-semibold">Step 3:</span> When the blue <strong class="text-radius-text-primary">SmartScreen Defender</strong> warning pops up:
            <ul class="list-disc list-inside ml-2 mt-1 space-y-1 text-radius-text-muted">
              <li>Click <span class="text-radius-text-primary font-medium">More info</span></li>
              <li>Click <span class="text-radius-text-primary font-medium">Run anyway</span></li>
            </ul>
          </div>
        </div>

        <!-- Manual downloads link -->
        <div class="border-t border-radius-border-subtle/50 pt-3">
          <p class="text-[9px] text-radius-text-muted mb-2">Manual download link</p>
          <a href={downloadUrls.winX64} class="text-radius-accent text-[10px] hover:underline flex items-center gap-1">
            radius-windows-x64.zip
          </a>
        </div>
      </div>
    </dialog>

    <script define:vars={{ downloadUrls, fallbackUrl }}>
      // CPU Arch / OS detection helper
      function detectAppleArch() {
        const ua = navigator.userAgent.toLowerCase();
        if (ua.includes("arm64") || ua.includes("aarch64")) return "arm";
        if (navigator.platform === "MacIntel") {
          // Fallback guess for modern Macs running translation but usually defaults to Apple Silicon nowadays
          if (typeof navigator.userAgentData?.getHighEntropyValues === "function") {
            return null;
          }
          return "arm";
        }
        return "intel";
      }

      // Dynamic OS Detection on mount
      const ua = navigator.userAgent.toLowerCase();
      let detectedOS = "unknown";

      if (ua.includes("mac")) {
        detectedOS = "mac";
      } else if (ua.includes("win")) {
        detectedOS = "windows";
      } else if (ua.includes("linux") && !ua.includes("android")) {
        detectedOS = "linux";
      }

      // DOM References
      const downloadBtn = document.getElementById("primary-download-btn");
      const downloadText = document.getElementById("primary-download-text");
      const downloadSubtext = document.getElementById("primary-download-subtext");
      const macIcon = document.getElementById("mac-icon");
      const winIcon = document.getElementById("win-icon");
      const genericIcon = document.getElementById("generic-icon");

      const macDialog = document.getElementById("macos-dialog");
      const winDialog = document.getElementById("windows-dialog");

      // Dynamic Content Swapping
      if (detectedOS === "mac") {
        if (downloadText) downloadText.textContent = "Download Beta for macOS";
        if (downloadSubtext) downloadSubtext.textContent = "Apple Silicon & Intel";
        macIcon?.classList.remove("hidden");
        genericIcon?.classList.add("hidden");
      } else if (detectedOS === "windows") {
        if (downloadText) downloadText.textContent = "Download Beta for Windows";
        if (downloadSubtext) downloadSubtext.textContent = "64-bit installer";
        winIcon?.classList.remove("hidden");
        genericIcon?.classList.add("hidden");
      } else if (detectedOS === "linux") {
        if (downloadText) downloadText.textContent = "Download Beta for Linux";
        if (downloadSubtext) downloadSubtext.textContent = "x64 .tar.gz";
        // Linux keeps the default download/generic icon, no class swap needed
      } else {
        if (downloadText) downloadText.textContent = "Download Beta for Desktop";
        if (downloadSubtext) downloadSubtext.textContent = "macOS, Windows, Linux";
      }

      // Primary click handler
      downloadBtn?.addEventListener("click", () => {
        if (detectedOS === "mac") {
          macDialog?.showModal();
          
          // Auto resolve Apple Silicon vs Intel
          const arch = detectAppleArch();
          let targetUrl = downloadUrls.macArm; // Default
          
          if (arch === "intel") {
            targetUrl = downloadUrls.macIntel;
          } else if (arch === null) {
            navigator.userAgentData?.getHighEntropyValues(["architecture"])
              .then((hint) => {
                if (hint?.architecture?.includes("x86")) {
                  window.location.href = downloadUrls.macIntel;
                } else {
                  window.location.href = downloadUrls.macArm;
                }
              })
              .catch(() => {
                window.location.href = downloadUrls.macArm;
              });
            return;
          }
          
          window.location.href = targetUrl;
        } else if (detectedOS === "windows") {
          winDialog?.showModal();
          window.location.href = downloadUrls.winX64;
        } else if (detectedOS === "linux") {
          window.location.href = downloadUrls.linuxX64;
        } else {
          // Fallback redirect to latest release
          window.location.href = fallbackUrl;
        }
      });

      // Dialog dismiss helpers (close buttons)
      document.querySelectorAll("[data-dialog-close]").forEach((btn) => {
        btn.addEventListener("click", () => {
          btn.closest("dialog")?.close();
        });
      });

      // Fallback click outside to close (light dismiss)
      document.querySelectorAll("dialog").forEach((dialog) => {
        if (!("closedBy" in HTMLDialogElement.prototype)) {
          dialog.addEventListener("click", (event) => {
            if (event.target !== dialog) return;
            const rect = dialog.getBoundingClientRect();
            const isInside = (
              rect.top <= event.clientY &&
              event.clientY <= rect.top + rect.height &&
              rect.left <= event.clientX &&
              event.clientX <= rect.left + rect.width
            );
            if (!isInside) {
              dialog.close();
            }
          });
        }
      });

      // Terminal quarantine command copy helper
      const copyBtn = document.getElementById("copy-mac-cmd");
      copyBtn?.addEventListener("click", async () => {
        const cmdEl = document.getElementById("mac-quarantine-cmd");
        const code = cmdEl?.textContent?.trim();
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code);
          const originalSvg = copyBtn.innerHTML;
          copyBtn.innerHTML = `
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-radius-success">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          `;
          setTimeout(() => {
            copyBtn.innerHTML = originalSvg;
          }, 1500);
        } catch {
          // Select manual fallback
          const selection = window.getSelection();
          const range = document.createRange();
          if (cmdEl) {
            range.selectNodeContents(cmdEl);
            selection?.removeAllRanges();
            selection?.addRange(range);
          }
        }
      });
    </script>
  </body>
</html>
