---
import RadiusMark from "../components/RadiusMark.astro";
import DownloadButton from "../components/DownloadButton.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Radius — a minimal, fast, distraction-free desktop email client for Gmail. Read-only. Local cache. Zero clutter." />
    <meta name="theme-color" content="#e0dbd3" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Radius — A quiet place for your email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="#" class="flex items-center gap-2.5 text-radius-text-primary">
          <RadiusMark class="w-5 h-5 text-radius-accent" />
          <span class="text-[13px] font-medium tracking-tight">Radius</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="#features" class="text-[12px] text-radius-text-secondary hover:text-radius-text-primary transition-colors duration-150">Features</a>
          <a href="#how-it-works" class="text-[12px] text-radius-text-secondary hover:text-radius-text-primary transition-colors duration-150">How it works</a>
          <a href="https://github.com/dipxsy/radius" target="_blank" rel="noopener" class="text-[12px] text-radius-text-secondary hover:text-radius-text-primary transition-colors duration-150">GitHub</a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative pt-32 pb-20 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col items-center text-center">
          <!-- Mark -->
          <div class="mb-10">
            <RadiusMark class="w-14 h-14 text-radius-accent" />
          </div>

          <!-- Masthead -->
          <h1 class="font-serif text-[52px] md:text-[72px] font-semibold text-radius-text-primary leading-[1.05] tracking-tight mb-6">
            Radius
          </h1>

          <!-- Tagline -->
          <p class="text-[15px] md:text-[17px] text-radius-text-muted leading-relaxed tracking-wide mb-4 max-w-md">
            A quiet place for your email.
          </p>

          <p class="text-[13px] text-radius-text-secondary leading-[1.7] mb-12 max-w-sm text-balance">
            A minimal, fast desktop client for Gmail. No clutter. No ads. No noise. Just your inbox, cached locally, ready the moment you open it.
          </p>

          <!-- Download -->
          <DownloadButton />

          <!-- Version note -->
          <p class="mt-6 text-[11px] text-radius-text-muted/60 tracking-wide">
            v1.0.0 &mdash; Free and open source under MIT
          </p>
        </div>
      </div>
    </section>

    <!-- App Preview -->
    <section class="px-6 pb-24">
      <div class="max-w-5xl mx-auto">
        <img
          src="/hero.jpeg"
          alt="Radius email client showing the inbox and reader view"
          class="w-full rounded-[14px] border border-radius-border shadow-[0_2px_40px_-12px_rgba(0,0,0,0.12)]"
          loading="eager"
        />
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="px-6 py-24 bg-radius-bg-primary">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-serif text-[32px] md:text-[40px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-4">
            Built for focus
          </h2>
          <p class="text-[14px] text-radius-text-muted max-w-md mx-auto">
            Every decision was made to remove friction. No tabs. No chat widgets. No promotions sidebar.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Feature 1 -->
          <div class="group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 hover:border-radius-border transition-colors duration-200">
            <div class="w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-radius-accent">
                <polyline points="13 2 13 9 20 9" />
                <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" />
              </svg>
            </div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2">Local cache</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              Your inbox syncs to a local SQLite database. Open the app &mdash; your emails are already there. No spinners. No waiting.
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 hover:border-radius-border transition-colors duration-200">
            <div class="w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-radius-accent">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
              </svg>
            </div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2">Typographic reader</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              Emails render in a centered 680px column with generous line height and system serif. Finally, an email client that respects the craft of reading.
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 hover:border-radius-border transition-colors duration-200">
            <div class="w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-radius-accent">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
            </div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2">Read-only by design</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              Radius only reads your inbox. No send, no delete, no archive. Your OAuth scope is minimal. Your trust is maximal.
            </p>
          </div>

          <!-- Feature 4 -->
          <div class="group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 hover:border-radius-border transition-colors duration-200">
            <div class="w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-radius-accent">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2">Always in sync</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              Background incremental sync via Gmail's history API. New emails appear without a manual refresh. The cache stays warm.
            </p>
          </div>

          <!-- Feature 5 -->
          <div class="group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 hover:border-radius-border transition-colors duration-200">
            <div class="w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-radius-accent">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2">Secure by default</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              OAuth tokens live in your system keychain, not a config file. HTML email bodies are sanitized before they ever reach the renderer.
            </p>
          </div>

          <!-- Feature 6 -->
          <div class="group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 hover:border-radius-border transition-colors duration-200">
            <div class="w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-radius-accent">
                <path d="M18 20V10" />
                <path d="M12 20V4" />
                <path d="M6 20v-6" />
              </svg>
            </div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2">120fps scrolling</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              Virtualized lists handle 10,000+ emails without breaking a sweat. Built with @tanstack/react-virtual and disciplined rendering.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="px-6 py-24">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-serif text-[32px] md:text-[40px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-4">
            How it works
          </h2>
          <p class="text-[14px] text-radius-text-muted max-w-md mx-auto">
            Three steps from install to inbox. No configuration files. No server to run.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="relative p-6 rounded-xl bg-radius-bg-primary border border-radius-border-subtle">
            <div class="absolute -top-3 left-6 px-2 py-0.5 bg-radius-frame-bg rounded text-[10px] font-medium text-radius-text-secondary">01</div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2 mt-1">Connect Gmail</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              One-click OAuth with PKCE. We request read-only access. You approve. That's it.
            </p>
          </div>

          <div class="relative p-6 rounded-xl bg-radius-bg-primary border border-radius-border-subtle">
            <div class="absolute -top-3 left-6 px-2 py-0.5 bg-radius-frame-bg rounded text-[10px] font-medium text-radius-text-secondary">02</div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2 mt-1">First sync</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              Radius fetches your inbox and stores it locally. A progress bar shows the way. For a thousand emails, this takes under a minute.
            </p>
          </div>

          <div class="relative p-6 rounded-xl bg-radius-bg-primary border border-radius-border-subtle">
            <div class="absolute -top-3 left-6 px-2 py-0.5 bg-radius-frame-bg rounded text-[10px] font-medium text-radius-text-secondary">03</div>
            <h3 class="text-[14px] font-semibold text-radius-text-primary mb-2 mt-1">Just read</h3>
            <p class="text-[13px] text-radius-text-secondary leading-relaxed">
              From now on, Radius opens instantly. Background sync keeps you current. No waiting. No loading states. Just email.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy / Why -->
    <section class="px-6 py-24 bg-radius-bg-primary">
      <div class="max-w-3xl mx-auto text-center">
        <RadiusMark class="w-8 h-8 text-radius-accent mx-auto mb-6" />
        <blockquote class="font-serif text-[24px] md:text-[30px] font-medium text-radius-text-primary leading-[1.35] tracking-tight mb-6">
          &ldquo;Speed is the feature. Silence is the interface.&rdquo;
        </blockquote>
        <p class="text-[14px] text-radius-text-secondary leading-relaxed max-w-xl mx-auto mb-8">
          We built Radius because existing email clients treat your attention as inventory to be sold. Ads in the sidebar. Promotions in your primary tab. Chat widgets sliding over your draft. Every pixel is a negotiation.
        </p>
        <p class="text-[14px] text-radius-text-secondary leading-relaxed max-w-xl mx-auto">
          Radius does less, better. One account. One inbox. One beautiful reader. If you need a power tool, this isn't it. If you need a quiet place to read your email &mdash; welcome.
        </p>
      </div>
    </section>

    <!-- Tech stack / Open source -->
    <section class="px-6 py-24">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="font-serif text-[28px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-4">
              Open source, end to end
            </h2>
            <p class="text-[14px] text-radius-text-secondary leading-relaxed mb-6">
              Radius is MIT licensed. The entire stack &mdash; from the sync engine to the renderer &mdash; is plain TypeScript. No hidden binaries. No telemetry. No dependencies you can't audit.
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              {["Electrobun", "Bun", "React", "Tailwind CSS", "SQLite", "TypeScript"].map((tech) => (
                <span class="px-2.5 py-1 text-[11px] text-radius-text-secondary bg-radius-bg-secondary border border-radius-border-subtle rounded-md">
                  {tech}
                </span>
              ))}
            </div>
            <a
              href="https://github.com/DeepanshuMishraa/radius"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-[13px] text-radius-accent hover:text-radius-accent-hover transition-colors duration-150"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              View source on GitHub
            </a>
          </div>

          <div class="p-6 rounded-xl bg-radius-bg-secondary border border-radius-border-subtle">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-2 h-2 rounded-full bg-radius-success"></div>
              <span class="text-[11px] text-radius-text-muted font-medium uppercase tracking-wide">System requirements</span>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-between py-2 border-b border-radius-border-subtle/50">
                <span class="text-[13px] text-radius-text-secondary">macOS</span>
                <span class="text-[12px] text-radius-text-primary">12.0+ (Monterey)</span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-radius-border-subtle/50">
                <span class="text-[13px] text-radius-text-secondary">Windows</span>
                <span class="text-[12px] text-radius-text-primary">10+ (64-bit)</span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-radius-border-subtle/50">
                <span class="text-[13px] text-radius-text-secondary">Linux</span>
                <span class="text-[12px] text-radius-text-primary">AppImage (x64)</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span class="text-[13px] text-radius-text-secondary">Required</span>
                <span class="text-[12px] text-radius-text-primary">Gmail account</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-6 py-24 bg-radius-bg-primary">
      <div class="max-w-2xl mx-auto">
        <h2 class="font-serif text-[28px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-10 text-center">
          Questions
        </h2>

        <div class="space-y-1">
          {[
            {
              q: "Does Radius work with Outlook or other providers?",
              a: "Not yet. Radius is Gmail-only for v1.0. IMAP support is on the roadmap for a future release."
            },
            {
              q: "Can I compose or send emails?",
              a: "No. Radius is intentionally read-only. It is designed for reading, not managing, your inbox. If you need to reply, your browser is one click away."
            },
            {
              q: "Where is my data stored?",
              a: "Locally on your machine in a SQLite database. Nothing leaves your device except API calls to Gmail's servers."
            },
            {
              q: "Is there a mobile app?",
              a: "No. Radius is a desktop application only. The focus is on a calm, full-screen reading experience that phones can't provide."
            },
            {
              q: "Will you add AI features?",
              a: "No plans to. The product philosophy is subtraction, not addition."
            },
            {
              q: "How do I report a bug or request a feature?",
              a: "Open an issue on GitHub. We read everything, even if we don't respond to every request."
            },
          ].map((item) => (
            <details class="group rounded-lg bg-radius-bg-secondary/50 border border-radius-border-subtle open:border-radius-border transition-colors duration-150">
              <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-[13px] font-medium text-radius-text-primary select-none list-none">
                {item.q}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-radius-text-muted shrink-0 ml-4 group-open:rotate-180 transition-transform duration-200"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <div class="px-5 pb-4 text-[13px] text-radius-text-secondary leading-relaxed">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="px-6 py-24">
      <div class="max-w-xl mx-auto text-center">
        <RadiusMark class="w-10 h-10 text-radius-accent mx-auto mb-6" />
        <h2 class="font-serif text-[28px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-4">
          Ready for a quieter inbox?
        </h2>
        <p class="text-[14px] text-radius-text-muted mb-8">
          Free. Open source. No account required.
        </p>
        <DownloadButton />
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-8 border-t border-radius-border-subtle">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-radius-text-muted">
          <RadiusMark class="w-4 h-4" />
          <span class="text-[12px]">Radius</span>
          <span class="text-[11px] text-radius-border">&middot;</span>
          <span class="text-[11px]">MIT License</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="https://github.com/dipxsy/radius" target="_blank" rel="noopener" class="text-[12px] text-radius-text-muted hover:text-radius-text-secondary transition-colors duration-150">GitHub</a>
          <a href="https://github.com/dipxsy/radius/releases" target="_blank" rel="noopener" class="text-[12px] text-radius-text-muted hover:text-radius-text-secondary transition-colors duration-150">Releases</a>
          <a href="https://github.com/dipxsy/radius/issues" target="_blank" rel="noopener" class="text-[12px] text-radius-text-muted hover:text-radius-text-secondary transition-colors duration-150">Issues</a>
        </div>
      </div>
    </footer>

    <!-- Entrance animations -->
    <style is:global>
      @keyframes fade-up {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .animate-fade-up {
        animation: fade-up 600ms cubic-bezier(0.32, 0.72, 0, 1) forwards;
      }

      @media (prefers-reduced-motion: reduce) {
        .animate-fade-up {
          animation: none;
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </body>
</html>