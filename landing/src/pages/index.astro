        <!-- Entrance animations -->
        <style is:global>
            /* ============================================
         Emil Kowalski Animation Principles
         - ease-out as default (cubic-bezier(0.32, 0.72, 0, 1))
         - max 300ms for UI transitions
         - transform + opacity only
         - scale(0.97) for button press feedback
         - staggered children entrances
         - reduced motion support
         ============================================ */

            :root {
                --ease-out-expo: cubic-bezier(0.32, 0.72, 0, 1);
                --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
                --duration-fast: 150ms;
                --duration-normal: 200ms;
                --duration-slow: 300ms;
            }

            /* --- Scroll-triggered entrance animations --- */
            @keyframes fade-up {
                from {
                    opacity: 0;
                    transform: translateY(16px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes fade-in {
                from {
                    opacity: 0;
                }
                to {
                    opacity: 1;
                }
            }

            @keyframes scale-in {
                from {
                    opacity: 0;
                    transform: scale(0.95);
                }
                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            /* Hero entrance sequence */
            .hero-mark {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 100ms forwards;
            }
            .hero-content h1 {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 180ms forwards;
            }
            .hero-tagline {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 260ms forwards;
            }
            .hero-body {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 340ms forwards;
            }
            .hero-download {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 420ms forwards;
            }
            .hero-version {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 500ms forwards;
            }

            /* Preview image */
            .preview-frame {
                opacity: 0;
                animation: scale-in 600ms var(--ease-out-expo) 600ms forwards;
            }

            /* Section headers */
            .section-header {
                opacity: 0;
            }
            .section-header.is-visible {
                animation: fade-up 500ms var(--ease-out-expo) forwards;
            }

            /* Feature cards — staggered */
            .feature-card {
                opacity: 0;
                transform: translateY(12px);
                transition:
                    border-color var(--duration-normal) var(--ease-out),
                    transform var(--duration-normal) var(--ease-out);
            }
            .feature-card.is-visible {
                animation: fade-up 400ms var(--ease-out-expo) forwards;
            }

            /* Stagger delays applied via JS or nth-child */
            .features-grid .feature-card:nth-child(1) {
                animation-delay: 0ms;
            }
            .features-grid .feature-card:nth-child(2) {
                animation-delay: 50ms;
            }
            .features-grid .feature-card:nth-child(3) {
                animation-delay: 100ms;
            }
            .features-grid .feature-card:nth-child(4) {
                animation-delay: 150ms;
            }
            .features-grid .feature-card:nth-child(5) {
                animation-delay: 200ms;
            }
            .features-grid .feature-card:nth-child(6) {
                animation-delay: 250ms;
            }
            .features-grid .feature-card:nth-child(7) {
                animation-delay: 300ms;
            }
            .features-grid .feature-card:nth-child(8) {
                animation-delay: 350ms;
            }
            .features-grid .feature-card:nth-child(9) {
                animation-delay: 400ms;
            }

            /* Feature card hover: icon lift */
            .feature-card:hover {
                border-color: var(--color-radius-border);
            }
            .feature-card:hover .feature-icon {
                transform: translateY(-2px);
            }
            .feature-icon {
                transition: transform var(--duration-normal) var(--ease-out);
            }

            /* Step cards */
            .step-card {
                opacity: 0;
                transform: translateY(12px);
            }
            .step-card.is-visible {
                animation: fade-up 400ms var(--ease-out-expo) forwards;
            }
            .steps-grid .step-card:nth-child(1) {
                animation-delay: 0ms;
            }
            .steps-grid .step-card:nth-child(2) {
                animation-delay: 80ms;
            }
            .steps-grid .step-card:nth-child(3) {
                animation-delay: 160ms;
            }

            /* Tech tags */
            .tech-tag {
                transition:
                    border-color var(--duration-fast) var(--ease-out),
                    transform var(--duration-fast) var(--ease-out);
            }
            .tech-tag:hover {
                border-color: var(--color-radius-border);
                transform: translateY(-1px);
            }

            /* Spec rows */
            .spec-row {
                opacity: 0;
                transform: translateX(-8px);
            }
            .spec-row.is-visible {
                animation: fade-up 300ms var(--ease-out-expo) forwards;
            }
            .specs-card .spec-row:nth-child(2) {
                animation-delay: 0ms;
            }
            .specs-card .spec-row:nth-child(3) {
                animation-delay: 60ms;
            }
            .specs-card .spec-row:nth-child(4) {
                animation-delay: 120ms;
            }
            .specs-card .spec-row:nth-child(5) {
                animation-delay: 180ms;
            }

            /* GitHub link hover */
            .github-link {
                transition: color var(--duration-fast) var(--ease-out);
            }
            .github-link:hover {
                color: var(--color-radius-accent-hover);
            }

            /* FAQ */
            .faq-item {
                transition: border-color var(--duration-fast) var(--ease-out);
            }
            .faq-summary {
                transition: color var(--duration-fast) var(--ease-out);
            }
            .faq-summary:hover {
                color: var(--color-radius-text-primary);
            }
            .faq-chevron {
                transition: transform 200ms var(--ease-out-expo);
            }
            .faq-item[open] .faq-chevron {
                transform: rotate(180deg);
            }
            .faq-answer {
                animation: fade-in 200ms var(--ease-out);
            }

            /* Nav links */
            .nav-link {
                position: relative;
                transition: color var(--duration-fast) var(--ease-out);
            }
            .nav-link:hover {
                color: var(--color-radius-text-primary);
            }
            .nav-link::after {
                content: "";
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 100%;
                height: 1px;
                background: currentColor;
                transform: scaleX(0);
                transform-origin: left;
                transition: transform 200ms var(--ease-out-expo);
            }
            .nav-link:hover::after {
                transform: scaleX(1);
            }

            /* Footer links */
            .footer-link {
                transition: color var(--duration-fast) var(--ease-out);
            }
            .footer-link:hover {
                color: var(--color-radius-text-secondary);
            }

            /* Copy button */
            .copy-btn {
                transition:
                    background-color var(--duration-fast) var(--ease-out),
                    color var(--duration-fast) var(--ease-out),
                    transform 100ms var(--ease-out);
            }
            .copy-btn:active {
                transform: scale(0.93);
            }

            /* Unsigned notice entrance */
            .unsigned-notice {
                opacity: 0;
                animation: fade-up 500ms var(--ease-out-expo) 400ms forwards;
            }

            /* Responsive nav */
            @media (max-width: 400px) {
                nav .flex.items-center.gap-6 {
                    gap: 1rem;
                }
                nav .nav-link {
                    font-size: 11px;
                }
            }

            /* Reduced motion */
            @media (prefers-reduced-motion: reduce) {
                .hero-mark,
                .hero-content h1,
                .hero-tagline,
                .hero-body,
                .hero-download,
                .hero-version,
                .unsigned-notice,
                .preview-frame,
                .section-header,
                .feature-card,
                .step-card,
                .spec-row {
                    animation: none;
                    opacity: 1;
                    transform: none;
                }
                .faq-chevron {
                    transition: none;
                }
                .feature-icon,
                .tech-tag,
                .nav-link::after {
                    transition: none;
                }
            }
        </style>

        <!-- Copy button -->
        <script>
            document.querySelectorAll("[data-copy-target]").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const targetId = btn.getAttribute("data-copy-target");
                    const code = document
                        .getElementById(targetId as string)
                        ?.textContent?.trim();
                    if (!code) return;

                    try {
                        await navigator.clipboard.writeText(code);
                        const original = btn.innerHTML;
                        btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
                        btn.classList.add("text-radius-success");
                        setTimeout(() => {
                            btn.innerHTML = original;
                            btn.classList.remove("text-radius-success");
                        }, 1500);
                    } catch {
                        // Fallback: select the text
                        const el = document.getElementById(targetId as string);
                        if (el) {
                            const range = document.createRange();
                            range.selectNode(el);
                            window.getSelection()?.removeAllRanges();
                            window.getSelection()?.addRange(range);
                        }
                    }
                });
            });
        </script>

        <!-- Intersection Observer for scroll-triggered animations -->
        <script>
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                            observer.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
            );

            document
                .querySelectorAll(
                    ".section-header, .feature-card, .step-card, .spec-row",
                )
                .forEach((el) => observer.observe(el));
        </script>
    </body>
