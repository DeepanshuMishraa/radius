---
import RadiusMark from "../components/RadiusMark.astro";
import DownloadButton from "../components/DownloadButton.astro";
import "../styles/global.css";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta
            name="description"
            content="Radius — a minimal, fast, distraction-free desktop email client for Gmail. Read-only. Local cache. Dark mode. Zero clutter."
        />
        <meta name="theme-color" content="#e0dbd3" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>Radius — A quiet place for your email</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>

    <body class="min-h-screen">
        <!-- Navigation -->
        <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
            <div class="max-w-5xl mx-auto flex items-center justify-between">
                <a
                    href="#"
                    class="nav-logo flex items-center gap-2.5 text-radius-text-primary"
                >
                    <RadiusMark class="w-5 h-5 text-radius-accent" />
                    <span class="text-[13px] font-medium tracking-tight"
                        >Radius</span
                    >
                </a>
                <div class="flex items-center gap-6">
                    <a
                        href="#features"
                        class="nav-link text-[12px] text-radius-text-secondary transition-colors duration-150"
                        >Features</a
                    >
                    <a
                        href="#how-it-works"
                        class="nav-link text-[12px] text-radius-text-secondary transition-colors duration-150"
                        >How it works</a
                    >
                    <a
                        href="https://github.com/DeepanshuMishraa/radius"
                        target="_blank"
                        rel="noopener"
                        class="nav-link text-[12px] text-radius-text-secondary transition-colors duration-150"
                        >GitHub</a
                    >
                </div>
            </div>
        </nav>

        <!-- Hero -->
        <section class="relative pt-10 pb-20 px-6">
            <div class="max-w-5xl mx-auto">
                <div
                    class="hero-content flex flex-col items-center text-center"
                >
                    <!-- Mark -->
                    <div class="hero-mark mb-10">
                        <RadiusMark class="w-14 h-14 text-radius-accent" />
                    </div>

                    <!-- Masthead -->
                    <h1
                        class="font-serif text-[52px] md:text-[72px] font-semibold text-radius-text-primary leading-[1.05] tracking-tight mb-6"
                    >
                        Radius
                    </h1>

                    <!-- Tagline -->
                    <p
                        class="hero-tagline text-[15px] md:text-[17px] text-radius-text-muted leading-relaxed tracking-wide mb-4 max-w-md"
                    >
                        A quiet place for your email.
                    </p>

                    <p
                        class="hero-body text-[13px] text-radius-text-secondary leading-[1.7] mb-8 max-w-sm text-balance"
                    >
                        A minimal, fast desktop client for Gmail. No clutter. No
                        ads. No noise. Just your inbox, cached locally, ready
                        the moment you open it.
                    </p>

                    <!-- Unsigned app notice -->
                    <div
                        class="unsigned-notice w-full max-w-[28rem] mb-10 text-left"
                    >
                        <div
                            class="rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50 overflow-hidden"
                        >
                            <!-- Header -->
                            <div
                                class="flex items-center gap-2 px-4 py-3 border-b border-radius-border-subtle/60"
                            >
                                <svg
                                    width="13"
                                    height="13"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="text-radius-accent shrink-0"
                                >
                                    <path
                                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                                    ></path>
                                    <line x1="12" x2="12" y1="9" y2="13"></line>
                                    <line x1="12" x2="12.01" y1="17" y2="17"
                                    ></line>
                                </svg>
                                <p
                                    class="text-[11px] text-radius-text-muted leading-relaxed"
                                >
                                    This app is not code-signed. First-time
                                    install requires a quick manual step.
                                </p>
                            </div>

                            <!-- macOS -->
                            <div
                                class="px-4 py-3 border-b border-radius-border-subtle/40"
                            >
                                <div class="flex items-center gap-1.5 mb-2">
                                    <svg
                                        width="12"
                                        height="12"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                        class="text-radius-text-muted/70"
                                    >
                                        <path
                                            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.21-1.98 1.07-3.11-1.05.05-2.31.7-3.06 1.55-.67.76-1.26 1.99-1.1 3.13 1.17.09 2.36-.66 3.09-1.57z"
                                        ></path>
                                    </svg>
                                    <span
                                        class="text-[11px] font-medium text-radius-text-primary"
                                        >macOS</span
                                    >
                                </div>
                                <div class="flex items-stretch gap-1.5">
                                    <code
                                        id="mac-cmd"
                                        class="flex-1 min-w-0 text-[11px] font-mono text-radius-text-secondary bg-radius-bg-primary/70 rounded-md px-3 py-2 leading-relaxed break-all"
                                    >
                                        sudo xattr -rd com.apple.quarantine /Applications/Radius.app
                                    </code>
                                    <button
                                        type="button"
                                        data-copy-target="mac-cmd"
                                        class="copy-btn shrink-0 inline-flex items-center justify-center w-9 rounded-md bg-radius-bg-primary/70 text-radius-text-muted hover:text-radius-text-primary hover:bg-radius-bg-primary transition-all duration-150"
                                        aria-label="Copy command"
                                    >
                                        <svg
                                            width="14"
                                            height="14"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <rect
                                                x="9"
                                                y="9"
                                                width="13"
                                                height="13"
                                                rx="2"
                                                ry="2"></rect>
                                            <path
                                                d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                                            ></path>
                                        </svg>
                                    </button>
                                </div>
                                <p
                                    class="mt-2 text-[10px] text-radius-text-muted/70 leading-relaxed"
                                >
                                    Paste into Terminal after dragging Radius to
                                    Applications.
                                </p>
                            </div>

                            <!-- Windows -->
                            <div class="px-4 py-3">
                                <div class="flex items-center gap-1.5 mb-1.5">
                                    <svg
                                        width="12"
                                        height="12"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                        class="text-radius-text-muted/70"
                                    >
                                        <path
                                            d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"
                                        ></path>
                                    </svg>
                                    <span
                                        class="text-[11px] font-medium text-radius-text-primary"
                                        >Windows</span
                                    >
                                </div>
                                <p
                                    class="text-[11px] text-radius-text-secondary leading-relaxed"
                                >
                                    When SmartScreen appears, click <span
                                        class="text-radius-text-primary font-medium"
                                        >More info</span
                                    > then <span
                                        class="text-radius-text-primary font-medium"
                                        >Run anyway</span
                                    >.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Download -->
                    <div class="hero-download">
                        <DownloadButton />
                    </div>

                    <!-- Version note -->
                    <p
                        class="hero-version mt-6 text-[11px] text-radius-text-muted/60 tracking-wide"
                    >
                        macOS · Windows · Linux &mdash; Free and open source
                        under MIT
                    </p>
                </div>
            </div>
        </section>

        <!-- App Preview -->
        <section class="px-6 pb-24">
            <div class="max-w-5xl mx-auto">
                <div class="preview-frame">
                    <img
                        src="/hero.jpeg"
                        alt="Radius email client showing the inbox and reader view"
                        class="w-full rounded-[14px] border border-radius-border shadow-[0_2px_40px_-12px_rgba(0,0,0,0.12)]"
                        loading="eager"
                    />
                </div>
            </div>
        </section>

        <!-- Features -->
        <section id="features" class="px-6 py-24 bg-radius-bg-primary">
            <div class="max-w-5xl mx-auto">
                <div class="section-header text-center mb-16">
                    <h2
                        class="font-serif text-[32px] md:text-[40px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-4"
                    >
                        Built for focus
                    </h2>
                    <p
                        class="text-[14px] text-radius-text-muted max-w-md mx-auto"
                    >
                        Every decision was made to remove friction. No tabs. No
                        chat widgets. No promotions sidebar.
                    </p>
                </div>

                <div class="features-grid grid md:grid-cols-3 gap-8">
                    <!-- Feature 1 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <polyline points="13 2 13 9 20 9"></polyline>
                                <path
                                    d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Local cache
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Your inbox syncs to a local SQLite database. Open
                            the app &mdash; your emails are already there. No
                            spinners. No waiting.
                        </p>
                    </div>

                    <!-- Feature 2 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <path
                                    d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
                                ></path>
                                <path
                                    d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Typographic reader
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Emails render in a centered column with generous
                            line height and serif typography. Finally, an email
                            client that respects the craft of reading.
                        </p>
                    </div>

                    <!-- Feature 3 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <path
                                    d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Read-only by design
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Radius only reads your inbox. No send, no delete, no
                            archive. Your OAuth scope is minimal. Your trust is
                            maximal.
                        </p>
                    </div>

                    <!-- Feature 4 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Always in sync
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Background incremental sync via Gmail's history API.
                            New emails appear without a manual refresh. The
                            cache stays warm.
                        </p>
                    </div>

                    <!-- Feature 5 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <rect
                                    width="18"
                                    height="11"
                                    x="3"
                                    y="11"
                                    rx="2"
                                    ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Secure by default
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            OAuth tokens live in your system keychain, not a
                            config file. HTML email bodies are sanitized before
                            they ever reach the renderer.
                        </p>
                    </div>

                    <!-- Feature 6 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <path d="M18 20V10"></path>
                                <path d="M12 20V4"></path>
                                <path d="M6 20v-6"></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            120fps scrolling
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Virtualized lists handle 10,000+ emails without
                            breaking a sweat. Built with @tanstack/react-virtual
                            and disciplined rendering.
                        </p>
                    </div>

                    <!-- Feature 7 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <path
                                    d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Dark mode
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            A carefully tuned dark theme with warm grays, not
                            harsh blacks. Toggle via command palette or let your
                            system decide.
                        </p>
                    </div>

                    <!-- Feature 8 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <polyline points="4 17 10 11 4 5"></polyline>
                                <line x1="12" x2="20" y1="19" y2="19"></line>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Command palette
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Hit Cmd+K to toggle theme, search emails, or jump to
                            any action. Keyboard-first design for people who
                            prefer typing to clicking.
                        </p>
                    </div>

                    <!-- Feature 9 -->
                    <div
                        class="feature-card group p-6 rounded-xl border border-radius-border-subtle bg-radius-bg-secondary/50"
                    >
                        <div
                            class="feature-icon w-8 h-8 rounded-lg bg-radius-accent-subtle flex items-center justify-center mb-4"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                class="text-radius-accent"
                            >
                                <circle cx="11" cy="11" r="8"></circle>
                                <path d="m21 21-4.35-4.35"></path>
                            </svg>
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2"
                        >
                            Instant search
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Search across sender, subject, snippet, and full
                            body text. Results appear as you type. No server
                            round-trips &mdash; everything is local.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- How it works -->
        <section id="how-it-works" class="px-6 py-24">
            <div class="max-w-5xl mx-auto">
                <div class="section-header text-center mb-16">
                    <h2
                        class="font-serif text-[32px] md:text-[40px] font-semibold text-radius-text-primary leading-[1.15] tracking-tight mb-4"
                    >
                        How it works
                    </h2>
                    <p
                        class="text-[14px] text-radius-text-muted max-w-md mx-auto"
                    >
                        Three steps from install to inbox. No configuration
                        files. No server to run.
                    </p>
                </div>

                <div class="steps-grid grid md:grid-cols-3 gap-6">
                    <div
                        class="step-card relative p-6 rounded-xl bg-radius-bg-primary border border-radius-border-subtle"
                    >
                        <div
                            class="step-badge absolute -top-3 left-6 px-2 py-0.5 bg-radius-frame-bg rounded text-[10px] font-medium text-radius-text-secondary"
                        >
                            01
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2 mt-1"
                        >
                            Connect Gmail
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            One-click OAuth with PKCE. We request read-only
                            access. You approve. That's it.
                        </p>
                    </div>

                    <div
                        class="step-card relative p-6 rounded-xl bg-radius-bg-primary border border-radius-border-subtle"
                    >
                        <div
                            class="step-badge absolute -top-3 left-6 px-2 py-0.5 bg-radius-frame-bg rounded text-[10px] font-medium text-radius-text-secondary"
                        >
                            02
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2 mt-1"
                        >
                            First sync
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            Radius fetches your inbox and stores it locally. A
                            progress bar shows the way. For 3,000 emails,
                            this takes under a minute.
                        </p>
                    </div>

                    <div
                        class="step-card relative p-6 rounded-xl bg-radius-bg-primary border border-radius-border-subtle"
                    >
                        <div
                            class="step-badge absolute -top-3 left-6 px-2 py-0.5 bg-radius-frame-bg rounded text-[10px] font-medium text-radius-text-secondary"
                        >
                            03
                        </div>
                        <h3
                            class="text-[14px] font-semibold text-radius-text-primary mb-2 mt-1"
                        >
                            Just read
                        </h3>
                        <p
                            class="text-[13px] text-radius-text-secondary leading-relaxed"
                        >
                            From now on, Radius opens instantly. Background sync
                            keeps you current. No waiting. No loading states.
                            Just email.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Philosophy / Why -->
        <section class="px-6 py-24 bg-radius-bg-primary">
            <div class="max-w-3xl mx-auto text-center">
                <RadiusMark class="w-8 h-8 text-radius-accent mx-auto mb-6" />
                <blockquote
                    class="font-serif text-[24px] md:text-[30px] font-medium text-radius-text-primary leading-[1.35] tracking-tight mb-6"
                >
                    &ldquo;Speed is the feature. Silence is the
                    interface.&rdquo;
                </blockquote>
                <p
                    class="text-[14px] text-radius-text-secondary leading-relaxed max-w-xl mx-auto mb-8"
                >
                    We built Radius because existing email clients treat your
                    attention as inventory to be sold. Ads in the sidebar.
