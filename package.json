{
  "name": "Radius",
  "version": "1.0.0",
  "description": "A Minimal and Clean Distraction Free Client",
  "scripts": {
    "generate:oauth-config": "bun run scripts/generate-oauth-config.ts",
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "bun run generate:oauth-config && vite build && electrobun build --env=canary",
    "build:dev": "bun install && bun run generate:oauth-config && electrobun build",
    "build:stable": "bun run generate:oauth-config && vite build && electrobun build --env=stable"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.1",
    "electrobun": "1.16.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
